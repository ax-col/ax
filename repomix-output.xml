      transition: all 0.2s;
    }

    .version-history-item:hover {
      background: rgba(0, 200, 255, 0.1);
      border-color: rgba(0, 200, 255, 0.3);
    }

    .version-history-item.current {
      background: rgba(0, 255, 65, 0.1);
      border-color: rgba(0, 255, 65, 0.4);
    }

    .version-history-item-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 6px;
    }

    .version-history-label {
      color: #fff;
      font-weight: 500;
    }

    .version-history-score {
      font-family: monospace;
      padding: 2px 8px;
      border-radius: 4px;
      font-size: 12px;
    }

    .version-history-score.elite { background: rgba(255, 215, 0, 0.2); color: #ffd700; }
    .version-history-score.excellent { background: rgba(0, 255, 65, 0.2); color: #00ff41; }
    .version-history-score.good { background: rgba(0, 191, 255, 0.2); color: #00bfff; }
    .version-history-score.acceptable { background: rgba(255, 170, 0, 0.2); color: #ffaa00; }
    .version-history-score.poor { background: rgba(255, 62, 62, 0.2); color: #ff3e3e; }

    /* Liquid Response in Magic Info */
    .liquid-version-history {
      margin-top: 8px;
    }
    .liquid-version-label {
      font-size: 9px;
      color: #888;
      margin-bottom: 4px;
    }
    .liquid-version-track {
      display: flex;
      gap: 4px;
      flex-wrap: wrap;
    }
    .liquid-version-item {
      display: flex;
      align-items: center;
      gap: 4px;
      padding: 4px 8px;
      background: rgba(0, 0, 0, 0.3);
      border: 1px solid rgba(100, 200, 255, 0.2);
      border-radius: 4px;
      cursor: pointer;
      transition: all 0.2s;
      font-size: 10px;
      font-family: monospace;
    }
    .liquid-version-item:hover {
      background: rgba(100, 200, 255, 0.15);
      border-color: rgba(100, 200, 255, 0.5);
      transform: scale(1.05);
    }
    .liquid-version-item.active {
      background: rgba(100, 200, 255, 0.2);
      border-color: #64c8ff;
      box-shadow: 0 0 6px rgba(100, 200, 255, 0.3);
    }
    .liquid-version-num {
      color: #888;
    }
    .liquid-version-score {
      color: #64c8ff;
      font-weight: 600;
    }
    .liquid-version-delta {
      color: #4ade80;
      font-size: 9px;
    }
    .liquid-improvements {
      margin-top: 6px;
      display: flex;
      flex-wrap: wrap;
      gap: 4px;
      align-items: center;
    }
    .liquid-improvements-label {
      font-size: 9px;
      color: #888;
      margin-right: 4px;
    }
    .liquid-improvement-tag {
      font-size: 9px;
      padding: 2px 6px;
      background: rgba(100, 200, 255, 0.15);
      border: 1px solid rgba(100, 200, 255, 0.3);
      border-radius: 3px;
      color: #64c8ff;
    }

    .version-history-meta {
      display: flex;
      gap: 12px;
      font-size: 11px;
      color: #888;
      margin-bottom: 6px;
    }

    .version-delta {
      color: #00ff41;
    }

    .version-time {
      color: #666;
    }

    .version-improvements {
      display: flex;
      flex-wrap: wrap;
      gap: 4px;
      margin-bottom: 6px;
    }

    .improvement-tag {
      background: rgba(0, 200, 255, 0.15);
      color: #00c8ff;
      padding: 2px 6px;
      border-radius: 4px;
      font-size: 10px;
    }

    .version-preview {
      color: #666;
      font-size: 11px;
      line-height: 1.4;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    /* Matrix Rain Animation for Liquid Mode */
    .matrix-rain-container {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      overflow: hidden;
      pointer-events: none;
      z-index: 10;
      border-radius: 8px;
    }

    .matrix-column {
      position: absolute;
      top: -100%;
      font-family: 'Courier New', monospace;
      font-size: 14px;
      line-height: 1;
      color: #00ff41;
      text-shadow: 0 0 8px #00ff41, 0 0 16px #00ff41;
      white-space: nowrap;
      animation: matrixFall linear forwards;
      opacity: 0;
    }

    @keyframes matrixFall {
      0% {
        transform: translateY(0);
        opacity: 0;
      }
      5% {
        opacity: 1;
      }
      85% {
        opacity: 1;
      }
      100% {
        transform: translateY(calc(100vh + 100%));
        opacity: 0;
      }
    }

    .matrix-rain-container.active {
      background: linear-gradient(180deg,
        rgba(0, 255, 65, 0.03) 0%,
        rgba(0, 0, 0, 0.1) 50%,
        rgba(0, 255, 65, 0.03) 100%);
    }

    .message-content.matrix-morphing {
      position: relative;
    }

    .message-content.matrix-morphing::after {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: linear-gradient(180deg,
        transparent 0%,
        rgba(0, 255, 65, 0.1) 50%,
        transparent 100%);
      animation: matrixSweep 0.8s ease-out forwards;
      pointer-events: none;
    }

    @keyframes matrixSweep {
      0% {
        transform: translateY(-100%);
        opacity: 1;
      }
      100% {
        transform: translateY(100%);
        opacity: 0;
      }
    }

    /* Glitch effect during morph */
    .matrix-glitch {
      animation: matrixGlitch 0.3s ease-in-out;
    }

    @keyframes matrixGlitch {
      0%, 100% {
        filter: none;
        transform: translate(0);
      }
      20% {
        filter: hue-rotate(90deg) saturate(2);
        transform: translate(-2px, 1px);
      }
      40% {
        filter: hue-rotate(-90deg) brightness(1.2);
        transform: translate(2px, -1px);
      }
      60% {
        filter: hue-rotate(45deg) contrast(1.2);
        transform: translate(-1px, 2px);
      }
      80% {
        filter: hue-rotate(-45deg);
        transform: translate(1px, -2px);
      }
    }

    /* Edit mode for user messages */
    .message.editing .message-content {
      display: none;
    }

    .message-edit-area {
      display: none;
      flex-direction: column;
      gap: 8px;
    }

    .message.editing .message-edit-area {
      display: flex;
    }

    .message-edit-textarea {
      background: var(--bg);
      border: 1px solid var(--primary);
      border-radius: 8px;
      padding: 12px;
      color: var(--text);
      font-family: inherit;
      font-size: 14px;
      resize: vertical;
      min-height: 60px;
      width: 100%;
    }

    .message-edit-textarea:focus {
      outline: none;
      box-shadow: 0 0 0 1px var(--primary);
