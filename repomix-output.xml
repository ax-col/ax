document.addEventListener('DOMContentLoaded', () => {
  animarTexto();
  
  if (document.getElementById('seconds-container')) {
    updateTimer();
    setInterval(updateTimer, 1000);
  }

  window.goldBitcoinWidget = new GoldBitcoinWidget();
});
