    res.json({
      id: req.params.model_id,
      object: 'model',
      created: CREATED,
      owned_by: 'openrouter',
      description: 'Passthrough to OpenRouter with full GODMODE pipeline (AutoTune + Parseltongue + STM).',
    })
    return
  }

  res.json({
