        gap: 24px;
    }
    
    .counter-card {
        min-width: 340px;
    }
    
    .counter-box {
        width: 340px;
    }
    
    .numbers-container {
        gap: 8px;
    }
    
    .number-display {
        width: 35px;
        height: 50px;
    }
    
    .number-digit {
        font-size: 16px;
    }
    
    .separator {
        font-size: 14px;
    }
}

@media (max-width: 400px) {
    .counter-card {
        min-width: 300px;
    }
    
    .counter-box {
        width: 300px;
        height: 85px;
    }
    
    .number-display {
        width: 30px;
        height: 45px;
    }
    
    .number-digit {
        font-size: 14px;
    }
    
    .separator {
        font-size: 12px;
