      background: linear-gradient(135deg, rgba(0, 200, 255, 0.1), rgba(100, 100, 255, 0.1));
    }

    .version-history-header h3 {
      margin: 0;
      color: #00c8ff;
      font-size: 16px;
    }

    .version-history-close {
      background: transparent;
      border: none;
      color: #888;
