    const BASE_URL = "https://ax-col.github.io/ax/rf.html";
    const SUPABASE_URL = "https://bkgklfnwqunogtqclrho.supabase.co";
    const SUPABASE_KEY = "sb_publishable_O0MJd3GpF_oL7TVdLdUYEQ_mwCy81A-"; 
    
