    .checkbox-group {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 10px 0;
      cursor: pointer;
      -webkit-tap-highlight-color: transparent;
    }

    .checkbox-group input[type="checkbox"] {
      -webkit-appearance: none;
      -moz-appearance: none;
      appearance: none;
      width: 28px;
      height: 28px;
      min-width: 28px;
