            { id: 5, nombre: "Hotel Orito Real", categoria: "hoteles", coords: [0.6688, -76.8705], horario: "Atención 24 Horas", descripcion: "Habitaciones cómodas con aire acondicionado y estacionamiento.", imagen: "https://images.unsplash.com/photo-1566073771259-6a8506099945?w=400&q=80" },
            { id: 7, nombre: "Sendero Ecológico Yarumo", categoria: "turismo", coords: [0.6923, -76.8531], horario: "Acceso Libre", descripcion: "Avistamiento de fauna y flora local junto al puente.", imagen: "https://images.unsplash.com/photo-1441974231531-c6227db76b6e?w=400&q=80" }
        ];

        function desvanecerYPublicarMapa() {
            if (mapInitialized) return;
            mapInitialized = true;

            document.getElementById('updateCountdownBox').style.display = 'none';
            document.getElementById('maintenanceModule').style.display = 'none';
            document.getElementById('mapModule').style.display = 'block';

            mapInstance = L.map('map').setView([0.6692, -76.8724], 16);

            L.tileLayer('https://mt1.google.com/vt/lyrs=y&x={x}&y={y}&z={z}', {
                maxZoom: 21,
                attribution: '&copy; Google Maps'
            }).addTo(mapInstance);

            renderizarMarcadores('todos');
        }

        function renderizarMarcadores(categoriaSeleccionada) {
            if (!mapInstance) return;
            marcadoresActivos.forEach(marker => mapInstance.removeLayer(marker));
            marcadoresActivos = [];

            catalogoLugares.forEach(lugar => {
                if (categoriaSeleccionada === 'todos' || lugar.categoria === categoriaSeleccionada) {
                    const nuevoMarcador = L.marker(lugar.coords);
                    const popupContenido = `
                        <div class="popup-card">
                            <img src="${lugar.imagen}" alt="${lugar.nombre}">
                            <div class="popup-title">${lugar.nombre}</div>
                            <span class="popup-meta">🕒 ${lugar.horario}</span>
                            <p class="popup-desc">${lugar.descripcion}</p>
                        </div>
                    `;
                    nuevoMarcador.bindPopup(popupContenido);
                    nuevoMarcador.addTo(mapInstance);
                    marcadoresActivos.push(nuevoMarcador);
                }
            });
        }

        function filtrarCategoria(categoria, botonPresionado) {
            const botones = document.querySelectorAll('.filter-btn');
            botones.forEach(btn => btn.classList.remove('active'));
            botonPresionado.classList.add('active');
            renderizarMarcadores(categoria);
        }

        const countdownInterval = setInterval(() => {
            const now = new Date().getTime();
            const difference = targetDate - now;

            if (difference <= 0) {
                clearInterval(countdownInterval);
                desvanecerYPublicarMapa();
            } else {
                const d = Math.floor(difference / (1000 * 60 * 60 * 24));
                const h = Math.floor((difference % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
                const m = Math.floor((difference % (1000 * 60 * 60)) / (1000 * 60));
                const s = Math.floor((difference % (1000 * 60)) / 1000);

                document.getElementById('days').textContent = d < 10 ? '0' + d : d;
                document.getElementById('hours').textContent = h < 10 ? '0' + h : h;
                document.getElementById('minutes').textContent = m < 10 ? '0' + m : m;
                document.getElementById('seconds').textContent = s < 10 ? '0' + s : s;
            }
        }, 1000);
    </script>
</body>
</html>
