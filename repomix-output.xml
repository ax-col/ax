    .form-group input:focus, .form-group select:focus {
      outline: none;
      border-color: var(--primary);
    }

    .api-key-link {
      display: inline-block;
      margin-top: 8px;
      font-size: 12px;
      color: var(--primary);
      text-decoration: none;
    }

