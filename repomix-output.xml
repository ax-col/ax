      state.ultraplinian = (mode === 'ultraplinian');
      state.plinyMode = (mode === 'pliny');
      // parseltongue = none of the above (sequential retry)

      // Close dropdown
      document.getElementById('modeSwitcher').classList.remove('open');

      // Update UI
      updateModeSwitcherUI();

      // Save state
      saveState();
