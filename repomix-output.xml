    step: 0.05,
    description: 'Nucleus sampling. Considers tokens within this cumulative probability.'
  },
  top_k: {
    label: 'Top K',
    short: 'TOP-K',
    min: 1,
    max: 100,
    step: 1,
    description: 'Limits token selection to the top K most likely tokens.'
  },
  frequency_penalty: {
    label: 'Frequency Penalty',
    short: 'FREQ',
    min: -2.0,
    max: 2.0,
    step: 0.05,
